# BuildSpec AI - Environment Configuration
# Copy this file to .env and fill in your values

# Required: OpenAI API Key
# Get yours at: https://platform.openai.com/api-keys
# Needs access to: text-embedding-3-small, gpt-4o
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Default debug mode (true/false)
# Shows raw model outputs and retrieved evidence
DEBUG_MODE=false
