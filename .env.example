# BuildSpec AI - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================================================
# REQUIRED: OpenAI API Key
# ============================================================================
# Get your API key at: https://platform.openai.com/api-keys
# Required access:
#   - gpt-4o-mini (chat completions)
#   - text-embedding-3-small (embeddings) — optional, TF-IDF fallback available
OPENAI_API_KEY=sk-your-api-key-here

# ============================================================================
# OPTIONAL: Default Settings
# ============================================================================
# Enable debug mode by default (true/false)
# Shows raw model outputs and retrieved evidence chunks
DEBUG_MODE=false

# ============================================================================
# DEPLOYMENT NOTES
# ============================================================================
# For Streamlit Cloud:
# - Do NOT commit .env file
# - Set OPENAI_API_KEY in Streamlit Cloud Secrets
# - Go to: https://share.streamlit.io → Your App → Settings → Secrets
#
# For local development:
# - Copy this file to .env
# - Replace sk-your-api-key-here with your actual API key
# - Run: streamlit run app.py
